{
    email {$ACME_EMAIL}
}

(app_proxy) {
    encode gzip

    handle_path /api/* {
        reverse_proxy backend:8000
    }

    handle {
        reverse_proxy frontend:80
    }
}

:80 {
    import app_proxy
}

{$DOMAIN} {
    tls /certs/savetear.cloud_bundle.crt /certs/savetear.cloud.key
    import app_proxy
}
